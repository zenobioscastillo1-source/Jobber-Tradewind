# Copy to .env and fill in. NEVER commit the real .env.
# All values are owner-supplied (see README.md and workflows/ingest_and_surface.md).

# --- Jobber app (Developer Center -> Manage Apps) ---
# OAuth client credentials for your registered Jobber app.
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
# Redirect URI registered on the app. Must match exactly. Used by the local
# auth-code catcher in tools/jobber_auth.py --authorize.
JOBBER_REDIRECT_URI=http://localhost:5000/callback
# REQUIRED on every GraphQL request. Date string (YYYY-MM-DD) of an active API
# version. Confirm the current version in the Developer Center changelog / GraphiQL.
JOBBER_API_VERSION=

# --- Google Sheet (the surfacing target / system of record) ---
# Copy the long ID from the sheet URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=
# Tab names inside that sheet.
REQUESTS_TAB=Requests
HYGIENE_TAB=Client Hygiene
STATE_TAB=_state
# Layer 2 (Draft & Propose) tabs — created automatically on first write.
DRAFTS_TAB=Follow-up Drafts
PROPOSALS_TAB=Cleanup Proposals

# Safety cap on how many Requests a single poll will fetch. Raising this is a
# bulk run and needs owner sign-off (see CLAUDE.md cost authorization).
MAX_FETCH=50

# Secrets/tokens live in gitignored files, NOT here:
#   jobber_token.json  - Jobber access+refresh tokens (created by --authorize, auto-refreshed)
#   credentials.json   - Google OAuth client (Desktop app)
#   token.json         - Google token (created on first consent, auto-refreshed)
